{
  "version": 2,
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/share", "dest": "/share.html" },
    { "src": "/sw.js", "dest": "/sw.js" },
    { "src": "/manifest.json", "dest": "/manifest.json" },
    { "src": "/fonts/(.*)", "dest": "/public/fonts/$1" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/(.*\\.(js|css|png|ico|json|ttf|woff|woff2))", "dest": "/$1" }
  ]
}
